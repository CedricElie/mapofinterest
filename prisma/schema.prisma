datasource db {
  provider = "sqlite"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  password  String
  createdAt DateTime @default(now())
  pois      Poi[]
}

model Category {
  id    String @id
  label String 
  color String
  pois  Poi[]
}

model Poi {
  id          String   @id @default(cuid())
  title       String
  description String?
  rating      Int?
  latitude    Float
  longitude   Float
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  createdAt   DateTime @default(now())
}
